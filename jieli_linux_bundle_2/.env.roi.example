# ===============================
# AC79 -> RK3588 ROI UI 配置示例
# 复制为 .env 后按你的板卡实际情况修改
# ===============================

# AC79 AP 模式常见地址；如果你不想过滤来源 IP，可设为空：DEVICE_IP=
DEVICE_IP=192.168.1.1
BIND_IP=0.0.0.0
UDP_PORT=2224
CLEANUP_TIMEOUT=3.0

# 模型路径：沿用原仓库 jieli_linux_bundle/model 目录
MODEL_PATH=./model/person.rknn
LABELS_PATH=./model/labels.txt
INPUT_WIDTH=640
INPUT_HEIGHT=640
OBJ_THRESH=0.25
NMS_THRESH=0.45
MAX_DET=10
AGNOSTIC_NMS=0
BGR_INPUT=1
SINGLE_CORE=1

# ROI 输出
ROI_JSON=./roi_ui_output/rois.json
SCREENSHOT_DIR=./roi_ui_output/screenshots
ROI_EVENT_LOG=./roi_ui_output/events.jsonl

# 启动 UI 前是否调用 start_ctp.sh 打开 AC79 视频流
START_CTP=1

# 报警联动命令，可先留空；后续可以替换为 CTP 音频播放脚本
# 示例：ALARM_CMD=python3 jieli_min_ctp_client.py --host 192.168.1.1 --cmd alarm
ALARM_CMD=
