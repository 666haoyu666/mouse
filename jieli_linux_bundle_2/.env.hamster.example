# ===== 基础网络 =====
BIND_IP=0.0.0.0
UDP_PORT=2224
DEVICE_IP=192.168.1.1

# ===== 检测后端 =====
DETECTOR_BACKEND=tensorrt
MODEL_PATH=./model/hamster.engine
LABELS_PATH=./model/hamster_labels.txt
CLASS_FILTER=
OBJ_THRESH=0.25
NMS_THRESH=0.45
INPUT_WIDTH=640
INPUT_HEIGHT=640
BGR_INPUT=1
MAX_DET=10
AGNOSTIC_NMS=0

# ===== UI 行为 =====
UI_TITLE=仓鼠场景监控 UI
AUTO_SEED_DEFAULT_ROIS=1
GRID_ENABLED=1
GRID_LABELS_ENABLED=1
ROI_DISTANCE_THRESHOLD=28
ROI_IOU_THRESHOLD=0.05
MAX_DESCRIPTION_REGIONS=2

# ===== 输出路径 =====
ROI_JSON=./roi_ui_output/hamster_rois.json
ROI_EVENT_LOG=./roi_ui_output/hamster_events.jsonl
SCREENSHOT_DIR=./roi_ui_output/screenshots
