# 杰理设备 IP 与端口
DEVICE_IP=192.168.1.1
UDP_PORT=2224
CTP_PORT=3333
HEARTBEAT=10

# 打开杰理实时流的参数
OPEN_W=640
OPEN_H=480
OPEN_FPS=20
OPEN_RATE=8000
OPEN_FMT=0

# 显示到 LCD
DISPLAY_NUM=:0.0
DISPLAY_W=1280
DISPLAY_H=800
SHOW_WINDOW=1

# 模型路径
MODEL_PATH=/home/elf/work/model/best_2.rknn
LABELS_PATH=/home/elf/work/model/labels.txt

# 推理阈值
OBJ_THRESH=0.25
NMS_THRESH=0.45
MAX_DET=5
AGNOSTIC_NMS=1
VERBOSE_INFER=0

# 可选项：如果你的模型输入需要 BGR，则改成 1
BGR_INPUT=0

# 可选项：只用单核 NPU
SINGLE_CORE=0

# 可选项：打印详细推理日志
VERBOSE_INFER=0


#会议室模式
MEETING_USE_START_SEC=5
MEETING_RELEASE_EMPTY_SEC=5
MEETING_LONG_USE_SEC=10
MEETING_ABNORMAL_EXTRA_SEC=10
MEETING_ABNORMAL_REPEAT_SEC=10
MEETING_RELEASE_AUDIO_GAP_SEC=3
MEETING_WORK_START=09:00
MEETING_WORK_END=18:00

#watchdog
VIDEO_FULL_RESTART_SEC=5
VIDEO_FULL_RESTART_SEC=8
VIDEO_FULL_RESTART_SEC=20