# ==============================
# 仓鼠监控系统 UI 第二阶段配置
# ==============================

# ===== 基础网络 =====
BIND_IP=0.0.0.0
UDP_PORT=2224
DEVICE_IP=192.168.1.1
CLEANUP_TIMEOUT=3.0

# ===== 检测后端 =====
# tensorrt：Jetson Orin Nano 推荐
# rknn：如果沿用 RKNN 版本检测脚本可选择
DETECTOR_BACKEND=tensorrt
MODEL_PATH=./model/hamster.engine
LABELS_PATH=./model/hamster_labels.txt
CLASS_FILTER=
OBJ_THRESH=0.25
NMS_THRESH=0.45
INPUT_WIDTH=640
INPUT_HEIGHT=640
BGR_INPUT=1
MAX_DET=10
AGNOSTIC_NMS=0

# ===== 第一阶段：检测 + 九宫格 + 固定 ROI + 中文描述 =====
UI_TITLE=仓鼠监控系统 UI - 第二阶段增强版
AUTO_SEED_DEFAULT_ROIS=1
GRID_ENABLED=1
GRID_LABELS_ENABLED=1
ROI_DISTANCE_THRESHOLD=28
ROI_IOU_THRESHOLD=0.05
MAX_DESCRIPTION_REGIONS=2

# ===== 第二阶段：多帧连续跟踪 =====
TRACKER_ENABLED=1
TRACKER_IOU_THRESHOLD=0.25
TRACKER_CENTER_DISTANCE=80
TRACKER_MAX_MISSED=20
TRACKER_MIN_HITS=1
TRAIL_LENGTH=40

# ===== 第二阶段：停留时间与行为规则 =====
DWELL_ENABLED=1
DWELL_THRESHOLD_SEC=10
LONG_STAY_THRESHOLD_SEC=30
ROI_STAY_THRESHOLD_SEC=8
STATIONARY_SPEED_THRESHOLD_PX=6
STATIONARY_THRESHOLD_SEC=12
ACTIVE_MOVE_THRESHOLD_PX=35
HIGH_ACTIVITY_WINDOW_SEC=20
HIGH_ACTIVITY_MIN_SWITCHES=5

# ===== 第二阶段：活动热区统计 =====
HEATMAP_ENABLED=1
HEATMAP_OVERLAY_ENABLED=0
HEATMAP_DECAY=0.995
HEATMAP_GRID_ROWS=3
HEATMAP_GRID_COLS=3
HEATMAP_TOP_K=3

# ===== 输出路径 =====
ROI_JSON=./roi_ui_output/hamster_rois.json
ROI_EVENT_LOG=./roi_ui_output/hamster_events.jsonl
STATS_JSON=./roi_ui_output/hamster_stats.json
SCREENSHOT_DIR=./roi_ui_output/screenshots
